# Auth0 SPA configuration. These are public client values (shipped in the JS bundle),
# not secrets — there is no client secret for a SPA (it uses PKCE).
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# Optional: backend base URL (defaults to http://localhost:8000).
# VITE_API_BASE=http://localhost:8000
